# Normalize line endings to LF on commit (cross-platform safe)
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Explicitly LF for JS/TS/JSON/SQL source files
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf
